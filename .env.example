# Jarvis Workstream API
JARVIS_WORKSTREAM_HOST=127.0.0.1
JARVIS_WORKSTREAM_PORT=8787
JARVIS_WORKSTREAM_DB_PATH=data/workstream.sqlite3
JARVIS_SN13_DB_PATH=subnets/sn13/data/sn13.sqlite3
JARVIS_OPERATOR_REQUIRE_AUTH=1
JARVIS_OPERATOR_MAX_CLOCK_SKEW_SECONDS=300

# Configure operators with either a JSON map or one explicit operator pair.
# The effective operator count is the number of entries in JARVIS_OPERATOR_SECRETS_JSON.
JARVIS_OPERATOR_SECRETS_JSON={"operator_1":"change-me"}
# JARVIS_OPERATOR_ID=operator_1
# JARVIS_OPERATOR_SECRET=change-me

# SN13 operator source access
APIFY_API_TOKEN=
JARVIS_SN13_X_OPERATOR_ENABLED=0
JARVIS_SN13_REDDIT_OPERATOR_ENABLED=0

# SN13 archive/export
JARVIS_SN13_ARCHIVE_S3_BUCKET=
