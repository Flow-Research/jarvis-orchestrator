# Jarvis admin/runtime configuration.
# This file configures Jarvis services, not personal operator scraper agents.

# Workstream API server
JARVIS_WORKSTREAM_HOST=127.0.0.1
JARVIS_WORKSTREAM_PORT=8787
JARVIS_WORKSTREAM_DB_PATH=data/workstream.sqlite3
JARVIS_SN13_DB_PATH=subnets/sn13/data/sn13.sqlite3

# Workstream API auth
# Jarvis uses this server-side allowlist to verify which personal operators may
# call the workstream API. Operators receive their own operator_id + secret and
# use them in signed HTTP requests.
JARVIS_WORKSTREAM_REQUIRE_AUTH=1
JARVIS_WORKSTREAM_MAX_CLOCK_SKEW_SECONDS=300
JARVIS_WORKSTREAM_OPERATOR_SECRETS_JSON={"operator_1":"change-me"}

# SN13 archive/export
# Optional until the archive/upload pipeline is enabled.
JARVIS_SN13_ARCHIVE_S3_BUCKET=
JARVIS_SN13_ARCHIVE_S3_REGION=
JARVIS_SN13_ARCHIVE_S3_PREFIX=sn13
