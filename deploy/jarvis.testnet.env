# Jarvis Orchestrator deployment environment.
# This file configures Jarvis-owned services. Personal-operator source API keys
# do not belong here.

# Workstream API
JARVIS_WORKSTREAM_HOST=0.0.0.0
JARVIS_WORKSTREAM_PORT=8787
JARVIS_WORKSTREAM_DB_PATH=/app/data/workstream.sqlite3
JARVIS_SN13_DB_PATH=/app/subnets/sn13/data/sn13.sqlite3
JARVIS_WORKSTREAM_REQUIRE_AUTH=1
GARDEN_BASE_URL=
GARDEN_SERVICE_AUTH_TOKEN=
GARDEN_AUTH_TIMEOUT_SECONDS=5
GARDEN_REQUIRE_ACTIVE_SESSION=0

# Registration monitor and auto-join policy.
JARVIS_MONITOR_SUBTENSOR_NETWORK=finney
JARVIS_MONITOR_DATA_DIR=/app/data
JARVIS_MONITOR_PRICE_SOURCE=sdk
JARVIS_MONITOR_WALLET_NAME=sn13miner
JARVIS_MONITOR_WALLET_HOTKEY=default
JARVIS_MONITOR_WALLET_PATH=/wallets
JARVIS_MONITOR_PRICE_THRESHOLD_TAO=0.05
JARVIS_MONITOR_MAX_SPEND_TAO=0.05
JARVIS_MONITOR_AUTO_REGISTER=0
JARVIS_MONITOR_POLL_INTERVAL_SECONDS=300
JARVIS_MONITOR_MIN_POLL_INTERVAL_SECONDS=60
JARVIS_MONITOR_FLOOR_DETECTION=1
JARVIS_MONITOR_ADAPTIVE_POLLING=1

# Optional SN13 listener runtime profile.
JARVIS_SN13_LISTENER_WALLET_NAME=sn13miner
JARVIS_SN13_LISTENER_WALLET_HOTKEY=default
JARVIS_SN13_LISTENER_WALLET_PATH=/wallets
JARVIS_SN13_LISTENER_NETWORK=finney
JARVIS_SN13_LISTENER_PORT=8091
JARVIS_SN13_LISTENER_IP=0.0.0.0
JARVIS_SN13_LISTENER_CAPTURE_DIR=/app/subnets/sn13/listener/captures
JARVIS_SN13_LISTENER_OFFLINE=0

# SN13 archive configuration.
# Leave blank if archive upload is still disabled.
JARVIS_SN13_ARCHIVE_S3_BUCKET=
JARVIS_SN13_ARCHIVE_S3_REGION=us-east-1
JARVIS_SN13_ARCHIVE_S3_PREFIX=sn13

# Scheduler cadence and planner size.
JARVIS_SN13_SCHEDULER_INTERVAL_SECONDS=1200
JARVIS_SN13_DD_TIMEOUT_SECONDS=30
JARVIS_SN13_TARGET_ITEMS=5
JARVIS_SN13_RECENT_BUCKETS=1
JARVIS_SN13_MAX_TASKS=500
JARVIS_SN13_GRAVITY_CACHE_DIR=/app/subnets/sn13/cache/gravity

# Publication economics.
JARVIS_SN13_MAX_TASK_COST=20
JARVIS_SN13_EXPECTED_REWARD=30
JARVIS_SN13_EXPECTED_SUBMITTED=1200
JARVIS_SN13_EXPECTED_ACCEPTED=900
JARVIS_SN13_DUPLICATE_RATE=0.04
JARVIS_SN13_REJECTION_RATE=0.10
JARVIS_SN13_VALIDATION_PASS_PROBABILITY=0.95
JARVIS_SN13_PAYOUT_BASIS=accepted_scorable_record
JARVIS_SN13_OPERATOR_PAYOUT=7
JARVIS_SN13_SCRAPER_PROVIDER_COST=4
JARVIS_SN13_PROXY_COST=1
JARVIS_SN13_COMPUTE_COST=0.5
JARVIS_SN13_LOCAL_STORAGE_COST=0.25
JARVIS_SN13_EXPORT_STAGING_COST=0.25
JARVIS_SN13_UPLOAD_BANDWIDTH_COST=0.25
JARVIS_SN13_RETRY_COST=0.25
JARVIS_SN13_RISK_RESERVE=2
JARVIS_SN13_ARCHIVE_BUCKET_COST=0
JARVIS_SN13_S3_MODE=upstream_presigned
JARVIS_SN13_CURRENCY=USD
